REMIX_STUDIO_IMAGE=ghcr.io/shinchven/remix-studio:latest
APP_PORT=3000
APP_CONTAINER_NAME=remix-studio-app

POSTGRES_PORT=5432
POSTGRES_CONTAINER_NAME=remix-studio-postgres
POSTGRES_DB=remix_studio
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_now
POSTGRES_DATA_DIR=./volumes/postgres

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_CONTAINER_NAME=remix-studio-minio
MINIO_DATA_DIR=./volumes/minio

DATABASE_URL=postgresql://postgres:change_me_now@postgres:5432/remix_studio

AWS_REGION=us-east-1
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=change_me_now
S3_BUCKET=remix-studio
S3_EXPORT_BUCKET=remix-studio-exports
S3_PUBLIC_ENDPOINT=
S3_AUTO_CREATE_BUCKET=true

DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change_me_now
PROVIDER_ENCRYPTION_KEY=
JWT_SECRET=change_me_now
WEBAUTHN_RP_ID=
WEBAUTHN_RP_NAME=Remix Studio
