# ======== Ports ========
APP_PORT=3000
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ======== PostgreSQL (via Prisma) ========
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/remix_studio"

# S3 (MinIO)
# Set to http://localhost:19000 for local development (outside Docker)
# Set to http://minio:9000 for Docker Compose deployments
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=remix-studio
MINIO_EXPORT_BUCKET=remix-studio-exports

# ======== Auth ========
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=your_secure_password

# Provider Encryption Key: Must be a 64-character hex string (32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROVIDER_ENCRYPTION_KEY=
JWT_SECRET=your_jwt_secret_change_in_production
