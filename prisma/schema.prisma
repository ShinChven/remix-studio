// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  role         String   @default("user")
  status       String   @default("disabled")
  createdByUserId String?
  sessionVersion Int    @default(0)
  storageLimit BigInt   @default(5368709120) // 5GB in bytes
  twoFactorEnabled       Boolean  @default(false)
  twoFactorSecret        String?
  twoFactorTempSecret    String?
  twoFactorTempExpiresAt DateTime?
  googleDriveRefreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLoginAt  DateTime?

  providers     Provider[]
  libraries     Library[]
  projects      Project[]
  trashItems    TrashItem[]
  exportTasks   ExportTask[]
  deliveryTasks DeliveryTask[]
  passkeys      PasskeyCredential[]
  oauthAuthorizationCodes OAuthAuthorizationCode[]
  oauthAccessTokens       OAuthAccessToken[]
  oauthClients            OAuthClient[]
  personalAccessTokens    PersonalAccessToken[]
  sessions              UserSession[]
  createdByUser User? @relation("UserCreation", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdUsers  User[] @relation("UserCreation")
  createdInviteCodes InviteCode[] @relation("InviteCodeCreator")
  usedInviteCodes    InviteCode[] @relation("InviteCodeUser")
  inviteRedemptions  InviteRedemption[]

  @@index([createdByUserId])
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  tokenHash    String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model InviteCode {
  id              String   @id @default(uuid())
  codeHash        String   @unique
  codeEncrypted   String
  note            String?
  membershipTier  String   @default("free")
  maxUses         Int      @default(1)
  createdByUserId String
  usedByUserId    String?
  usedByEmail     String?
  createdAt       DateTime @default(now())
  usedAt          DateTime?
  expiresAt       DateTime?

  createdByUser User  @relation("InviteCodeCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  usedByUser    User? @relation("InviteCodeUser", fields: [usedByUserId], references: [id], onDelete: SetNull)
  redemptions   InviteRedemption[]

  @@index([createdByUserId])
  @@index([usedByUserId])
  @@index([codeHash])
}

model InviteRedemption {
  id           String   @id @default(uuid())
  inviteCodeId String
  userId       String   @unique
  email        String
  redeemedAt   DateTime @default(now())

  inviteCode InviteCode @relation(fields: [inviteCodeId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([inviteCodeId, redeemedAt])
}

model PasskeyCredential {
  id           String   @id @default(uuid())
  userId       String
  name         String
  credentialId String   @unique
  publicKey    String   @db.Text
  algorithm    String
  counter      BigInt   @default(0)
  transports   Json?
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Provider {
  id              String   @id @default(uuid())
  userId          String
  name            String
  type            String
  apiKeyEncrypted String?
  apiSecretEncrypted String?
  apiUrl          String?
  concurrency     Int      @default(1)
  models          Json?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobs Job[]

  @@index([userId])
}

model Library {
  id        String   @id @default(uuid())
  userId    String
  name      String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items LibraryItem[]

  @@index([userId])
  @@index([userId, createdAt])
}

model LibraryItem {
  id           String   @id @default(uuid())
  libraryId    String
  content      String   @db.Text
  title        String?
  tags         Json?    // String[]
  order        Int?
  thumbnailUrl String?
  optimizedUrl String?
  size         BigInt?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  library Library @relation(fields: [libraryId], references: [id], onDelete: Cascade)

  @@index([libraryId])
  @@index([libraryId, order])
  @@index([libraryId, createdAt])
}

model Project {
  id           String   @id @default(uuid())
  userId       String
  name         String
  type         String   @default("image") // "image", "text", or "video"
  status       String   @default("active") // "active" or "archived"
  providerId   String?
  aspectRatio  String?
  quality      String?
  format       String?
  shuffle      Boolean?
  modelConfigId String?
  prefix       String?
  background   String?
  systemPrompt String?  @db.Text
  temperature  Float?
  maxTokens    Int?
  // Video generation defaults
  duration     Int?     // seconds
  resolution   String?  // '720p' | '1080p' | '4k'
  sound        String?  // 'on' | 'off'
  lastQueueCount Int?
  createdAt    DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs          Job[]
  workflowItems WorkflowItem[]
  albumItems    AlbumItem[]
  exportTasks   ExportTask[]

  @@index([userId])
  @@index([userId, status])
}

model Job {
  id            String   @id @default(uuid())
  projectId     String
  userId        String
  prompt        String   @db.Text
  status        String   @default("pending")
  imageContexts Json?    // String[]
  videoContexts Json?    // String[]
  audioContexts Json?    // String[]
  imageUrl      String?
  thumbnailUrl  String?
  optimizedUrl  String?
  error         String?  @db.Text
  providerId    String?
  modelConfigId String?
  aspectRatio   String?
  quality       String?
  format        String?
  background    String?
  resultText    String?  @db.Text
  taskId        String?
  filename      String?
  size          BigInt?
  optimizedSize BigInt?
  thumbnailSize BigInt?
  // Video generation
  duration      Int?     // seconds
  resolution    String?  // '720p' | '1080p' | '4k'
  sound         String?  // 'on' | 'off'
  createdAt     DateTime @default(now())

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  provider Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([userId, status])
  @@index([status, taskId])
}

model WorkflowItem {
  id           String  @id @default(uuid())
  projectId    String
  type         String
  value        String? @db.Text
  order        Int     @default(0)
  thumbnailUrl String?
  optimizedUrl String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model AlbumItem {
  id            String   @id @default(uuid())
  projectId     String
  userId        String
  jobId         String?
  prompt        String?  @db.Text
  textContent   String?  @db.Text
  imageContexts Json?    // String[]
  videoContexts Json?    // String[]
  audioContexts Json?    // String[]
  imageUrl      String?
  thumbnailUrl  String?
  optimizedUrl  String?
  providerId    String?
  modelConfigId String?
  aspectRatio   String?
  quality       String?
  format        String?
  size          BigInt?
  optimizedSize BigInt?
  thumbnailSize BigInt?
  // Video-specific
  duration      Int?     // seconds
  resolution    String?  // '720p' | '1080p' | '4k'
  createdAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
}

model TrashItem {
  id            String   @id @default(uuid())
  userId        String
  projectId     String
  projectName   String
  jobId         String?
  prompt        String?  @db.Text
  textContent   String?  @db.Text
  imageContexts Json?    // String[]
  videoContexts Json?    // String[]
  audioContexts Json?    // String[]
  imageUrl      String?
  thumbnailUrl  String?
  optimizedUrl  String?
  providerId    String?
  modelConfigId String?
  aspectRatio   String?
  quality       String?
  format        String?
  size          BigInt?
  optimizedSize BigInt?
  thumbnailSize BigInt?
  duration      Int?
  resolution    String?
  createdAt     DateTime @default(now())
  deletedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ExportTask {
  id          String    @id @default(uuid())
  userId      String
  projectId   String?
  status      String    @default("pending")
  downloadUrl String?
  error       String?   @db.Text
  size        BigInt?
  data        Json?     // Flexible blob for any extra fields
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  // Queue fields
  claimedAt   DateTime?
  workerId    String?
  heartbeatAt DateTime?
  attempts    Int       @default(0)

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  deliveryTasks DeliveryTask[]

  @@index([userId])
  @@index([userId, projectId])
  @@index([status, createdAt])
}

model DeliveryTask {
  id               String    @id @default(uuid())
  userId           String
  exportTaskId     String
  destination      String    @default("drive")
  status           String    @default("pending")
  bytesTransferred BigInt    @default(0)
  totalBytes       BigInt?
  externalId       String?
  externalUrl      String?
  error            String?   @db.Text
  createdAt        DateTime  @default(now())
  expiresAt        DateTime?
  // Queue fields
  claimedAt        DateTime?
  workerId         String?
  heartbeatAt      DateTime?
  attempts         Int       @default(0)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  exportTask ExportTask @relation(fields: [exportTaskId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, createdAt])
}

// === MCP OAuth 2.0 ===

model OAuthClient {
  id                      String   @id @default(uuid())
  clientId                String   @unique
  createdByUserId         String?
  clientSecretHash        String?
  clientName              String?
  redirectUris            Json     // String[]
  grantTypes              Json     // String[] e.g. ["authorization_code"]
  responseTypes           Json     // String[] e.g. ["code"]
  tokenEndpointAuthMethod String   @default("client_secret_basic")
  scope                   String?
  clientIdIssuedAt        DateTime @default(now())
  clientSecretExpiresAt   DateTime?
  createdAt               DateTime @default(now())

  createdBy          User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  authorizationCodes OAuthAuthorizationCode[]
  accessTokens       OAuthAccessToken[]

  @@index([createdByUserId])
}

model OAuthAuthorizationCode {
  id                  String   @id @default(uuid())
  code                String   @unique
  clientId            String
  userId              String
  redirectUri         String
  scope               String?
  codeChallenge       String?
  codeChallengeMethod String?  @default("S256")
  expiresAt           DateTime
  used                Boolean  @default(false)
  createdAt           DateTime @default(now())

  client OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([clientId])
}

model OAuthAccessToken {
  id           String    @id @default(uuid())
  token        String    @unique
  clientId     String
  userId       String
  scope        String?
  expiresAt    DateTime
  refreshToken String?   @unique
  refreshExpiresAt DateTime?
  revoked      Boolean   @default(false)
  createdAt    DateTime  @default(now())

  client OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([refreshToken])
  @@index([userId])
}

model PersonalAccessToken {
  id          String    @id @default(uuid())
  userId      String
  name        String
  tokenHash   String    @unique
  tokenPrefix String    // first 8 chars for display (e.g. "pat_xxxx...")
  scope       String    @default("mcp:tools")
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revoked     Boolean   @default(false)
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
}
