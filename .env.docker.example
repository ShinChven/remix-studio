# ======== Ports ========
APP_PORT=3000
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ======== PostgreSQL (Docker network) ========
POSTGRES_DB=remix_studio
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/remix_studio

# ======== S3-compatible storage (MinIO in Compose) ========
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=remix-studio
S3_EXPORT_BUCKET=remix-studio-exports
AWS_REGION=us-east-1
S3_PUBLIC_ENDPOINT=
S3_AUTO_CREATE_BUCKET=true

# ======== Auth ========
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change_me_now

# Provider Encryption Key: Must be a 64-character hex string (32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROVIDER_ENCRYPTION_KEY=
JWT_SECRET=change_me_now
WEBAUTHN_ORIGIN=
WEBAUTHN_RP_ID=
WEBAUTHN_RP_NAME=Remix Studio
